{
  "$schema": "https://raw.githubusercontent.com/ErikReider/SwayNotificationCenter/main/resources/configSchema.json",

  "positionX": "right",
  "positionY": "top",

  "layer": "overlay",
  "control-center-layer": "top",

  "notification-window-width": 400,
  "control-center-width": 500,

  "notification-icon-size": 48,
  "notification-body-image-height": 120,
  "notification-body-image-width": 200,

  "timeout": 5,
  "timeout-low": 3,
  "timeout-critical": 0,

  "fit-to-screen": true,

  "keyboard-shortcuts": true,
  "image-visibility": "when-available",

  "transition-time": 200,
  "hide-on-action": true,
  "hide-on-clear": false,

  "widgets": [
    "title",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Notificaciones",
      "clear-all-button": true,
      "button-text": "Limpiar"
    }
  }
}
